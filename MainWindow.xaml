<Window x:Class="CCRouter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CCRouter — Profile Manager"
        Height="560" Width="820" MinHeight="480" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app.ico">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="FieldBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="PasswordBox" x:Key="FieldPwd">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="Padding" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" MinWidth="160"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: profile list -->
        <DockPanel Grid.Column="0" Background="#F5F5F5">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8,6">
                <Button Content="+ New" Style="{StaticResource ActionBtn}" Click="NewProfile_Click"/>
                <Button Content="Delete" Style="{StaticResource ActionBtn}" Click="DeleteProfile_Click"/>
            </StackPanel>

            <TextBlock Text="PROFILES" FontSize="10" FontWeight="SemiBold"
                       Foreground="#888" Margin="10,10,0,4" DockPanel.Dock="Top"/>

            <ListBox x:Name="ProfileList" Margin="6,0,6,0"
                     SelectionChanged="ProfileList_SelectionChanged"
                     BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <TextBlock Text="{Binding Name}" FontSize="13"/>
                            <TextBlock Text="● Active" FontSize="10" Foreground="#2196F3"
                                       Visibility="{Binding IsActiveDisplay}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#DDD"/>

        <!-- Right: edit form -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,14,18,14" x:Name="EditPanel">

                <TextBlock x:Name="FormTitle" Text="Select or create a profile"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <!-- Basic fields -->
                <Label Style="{StaticResource FieldLabel}" Content="Profile Name *"/>
                <TextBox x:Name="TxtName" Style="{StaticResource FieldBox}"/>

                <CheckBox x:Name="ChkDefault" Content="This is the Default Claude subscription (clears env vars)"
                          Margin="0,0,0,10" FontSize="12" Checked="ChkDefault_Changed" Unchecked="ChkDefault_Changed"/>

                <StackPanel x:Name="PanelApiFields">
                    <Label Style="{StaticResource FieldLabel}" Content="Base URL *"/>
                    <TextBox x:Name="TxtBaseUrl" Style="{StaticResource FieldBox}"
                             />

                    <Label Style="{StaticResource FieldLabel}" Content="Auth Token"/>
                    <PasswordBox x:Name="PwdToken" Style="{StaticResource FieldPwd}"/>

                    <Label Style="{StaticResource FieldLabel}" Content="API_TIMEOUT_MS"/>
                    <TextBox x:Name="TxtTimeout" Style="{StaticResource FieldBox}"
                             />

                    <Separator Margin="0,4,0,8"/>
                    <TextBlock Text="Model Mapping (optional)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#666" Margin="0,0,0,4"/>

                    <Label Style="{StaticResource FieldLabel}" Content="Opus model"/>
                    <TextBox x:Name="TxtOpus" Style="{StaticResource FieldBox}"
                             />

                    <Label Style="{StaticResource FieldLabel}" Content="Sonnet model"/>
                    <TextBox x:Name="TxtSonnet" Style="{StaticResource FieldBox}"
                             />

                    <Label Style="{StaticResource FieldLabel}" Content="Haiku model"/>
                    <TextBox x:Name="TxtHaiku" Style="{StaticResource FieldBox}"
                             />
                </StackPanel>

                <Separator Margin="0,4,0,8"/>

                <Label Style="{StaticResource FieldLabel}" Content="Global hotkey (e.g. CTRL+ALT+1)"/>
                <TextBox x:Name="TxtHotkey" Style="{StaticResource FieldBox}"
                         />

                <Label Style="{StaticResource FieldLabel}" Content="Note"/>
                <TextBox x:Name="TxtNote" Style="{StaticResource FieldBox}"
                         AcceptsReturn="True" Height="54" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="💾 Save" Style="{StaticResource ActionBtn}" Click="SaveProfile_Click"
                            Background="#2196F3" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="⚡ Set Active" Style="{StaticResource ActionBtn}" Click="SetActive_Click"/>
                    <Button Content="🔌 Test Connection" Style="{StaticResource ActionBtn}" Click="TestConnection_Click"/>
                </StackPanel>

                <TextBlock x:Name="TxtStatus" Margin="0,8,0,0" FontSize="11" TextWrapping="Wrap"/>

                <Separator Margin="0,14,0,8"/>

                <!-- App settings -->
                <TextBlock Text="App Settings" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <CheckBox x:Name="ChkAutostart" Content="Start with Windows"
                          FontSize="12" Margin="0,0,0,6" Checked="Autostart_Changed" Unchecked="Autostart_Changed"/>
                <CheckBox x:Name="ChkStartMin" Content="Start minimized to tray"
                          FontSize="12" Margin="0,0,0,6" Checked="StartMin_Changed" Unchecked="StartMin_Changed"/>
                <CheckBox x:Name="ChkPromptRestart" Content="Prompt to restart terminal/VSCode after switching profile"
                          FontSize="12" Margin="0,0,0,6" Checked="PromptRestart_Changed" Unchecked="PromptRestart_Changed"/>

                <TextBlock Text="Current ANTHROPIC_BASE_URL (env var):" FontSize="11" Foreground="#666" Margin="0,8,0,2"/>
                <TextBlock x:Name="TxtCurrentEnv" FontSize="11" Foreground="#2196F3" TextWrapping="Wrap"/>

                <TextBlock Text="Mirrored to:" FontSize="11" Foreground="#666" Margin="0,6,0,2"/>
                <TextBlock x:Name="TxtClaudeSettingsPath" FontSize="11" FontFamily="Consolas"
                           Foreground="#2196F3" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
