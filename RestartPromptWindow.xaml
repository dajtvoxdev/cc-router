<Window x:Class="CCRouter.RestartPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restart applications?"
        Width="480" Height="520" MinWidth="420" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Resources/app.ico">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtTitle"
                   Text="Switched profile" FontSize="15" FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1" Margin="0,4,0,12" TextWrapping="Wrap" Foreground="#555" FontSize="12">
            <Run Text="Cấu hình đã ghi vào "/>
            <Run Text="~/.claude/settings.json" FontFamily="Consolas"/>
            <Run Text=" — Claude Code chỉ cần "/>
            <Run Text="/exit" FontFamily="Consolas"/>
            <Run Text=" rồi gõ "/>
            <Run Text="claude" FontFamily="Consolas"/>
            <Run Text=" lại, không cần restart."/>
            <LineBreak/>
            <Run Text="Restart terminal/VSCode chỉ cần thiết nếu tool khác (cmd, IDE plugin…) đọc env vars trực tiếp."/>
        </TextBlock>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Terminals -->
                <TextBlock x:Name="TxtTermSection" Text="Terminals đang mở"
                           FontWeight="SemiBold" Margin="0,4,0,4" FontSize="12"/>
                <StackPanel x:Name="PanelTerminals" Margin="6,0,0,8"/>

                <!-- VSCode -->
                <TextBlock x:Name="TxtVsSection" Text="VSCode đang mở"
                           FontWeight="SemiBold" Margin="0,8,0,4" FontSize="12"/>
                <TextBlock Text="⚠ Sẽ mất thay đổi chưa lưu. Restore session phụ thuộc cài đặt VSCode."
                           Foreground="#D84315" FontSize="11" Margin="6,0,0,4" TextWrapping="Wrap"/>
                <StackPanel x:Name="PanelVsCode" Margin="6,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <CheckBox Grid.Row="3" x:Name="ChkDontAskAgain"
                  Content="Don't ask me again (có thể bật lại trong Settings)"
                  Margin="0,12,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Skip" Width="90" Height="28" Margin="0,0,8,0" Click="Skip_Click"/>
            <Button Content="Restart selected" Width="140" Height="28"
                    Background="#2196F3" Foreground="White" FontWeight="SemiBold" Click="Restart_Click"/>
        </StackPanel>
    </Grid>
</Window>
